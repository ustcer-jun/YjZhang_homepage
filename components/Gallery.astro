---
interface Props {
  title: string;
  folder: string;
  thumbnail: string;
  items: {
    type: 'image' | 'video';
    src: string;
    alt?: string;
  }[];
  locale?: string;
}

const { title, folder, thumbnail, items, locale = 'en' } = Astro.props;
---

<div class="p-2 border border-neutral-200 dark:border-neutral-800 rounded-lg hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors cursor-pointer" data-folder={folder} data-items={JSON.stringify(items)} onclick="openGallery(this)">
  <div class="w-full h-48 rounded overflow-hidden">
    {items && items.length > 0 ? (
      items[0]?.type === 'image' ? (
        <div class="w-full h-full flex items-center justify-center bg-neutral-100 dark:bg-neutral-800">
          <img src={items[0].src} alt={items[0].alt || title} class="w-full h-full object-cover" />
        </div>
      ) : (
        <div class="relative w-full h-48 bg-neutral-100 dark:bg-neutral-800">
          <video class="w-full h-full object-cover" muted preload="metadata" playsinline>
            <source src={items[0].src} type={items[0].src.endsWith('.MOV') || items[0].src.endsWith('.mov') ? 'video/quicktime' : 'video/mp4'} />
          </video>
          <div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-30 opacity-0 hover:opacity-100 transition-opacity">
            <span class="text-4xl text-white drop-shadow-lg">▶</span>
          </div>
        </div>
      )
    ) : (
      <div class="w-full h-full bg-neutral-200 dark:bg-neutral-700 flex items-center justify-center">
        <span class="text-neutral-400">+</span>
      </div>
    )}
  </div>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 text-center mt-2">
    {locale === 'zh' ? 
      (title === 'Chengdu' ? '成都' : 
       title === 'Hefei' ? '合肥' : 
       title === 'Henan' ? '河南' : 
       title === 'Jiuzhaigou' ? '九寨沟' : 
       title === 'Lanzhou' ? '兰州' : 
       title === 'Qingdao' ? '青岛' : 
       title === 'Wuhan' ? '武汉' : 
       title === 'Xiamen' ? '厦门' : 
       title === 'Campus Share' ? '校园分享' : 
       title === 'Game Share' ? '游戏分享' : 
       title === 'Concert Share' ? '音乐会分享' : 
       title === 'Research' ? '科研' : 
       title)
      : title
    }
  </p>
</div>

<script is:inline>
  // Gallery modal functionality
  function openGallery(element) {
    const folder = element.getAttribute('data-folder');
    const items = JSON.parse(element.getAttribute('data-items'));
    
    if (!items || items.length === 0) {
      alert('No content available in this gallery');
      return;
    }
    
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-90 flex flex-col z-50';
    
    // Header
    const header = document.createElement('div');
    header.className = 'flex justify-between items-center p-4 border-b border-white border-opacity-20';
    header.innerHTML = `
      <h3 class="text-white text-xl">${folder.split('/').pop()}</h3>
      <button class="text-white text-2xl" onclick="this.closest('.fixed').remove()">&times;</button>
    `;
    modal.appendChild(header);
    
    // Content
    const content = document.createElement('div');
    content.className = 'flex-1 overflow-auto p-4';
    let contentHTML = '<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">';
    
    for (let i = 0; i < items.length; i++) {
      const item = items[i];
      contentHTML += '<div class="p-2 border border-white border-opacity-20 rounded-lg">';
      
      if (item.type === 'image') {
        contentHTML += `<div class="w-full h-48 flex items-center justify-center bg-neutral-100 dark:bg-neutral-800 rounded">
          <img src="${item.src}" alt="${item.alt || ''}" class="w-full h-full object-cover rounded cursor-pointer hover:opacity-90 transition-opacity" onclick="openModalWithGallery('${item.src}', '${item.alt || ''}', ${JSON.stringify(items).replace(/"/g, '&quot;')})" />
        </div>`;
      } else {
        contentHTML += `
          <div class="relative w-full h-48 bg-neutral-800 rounded cursor-pointer hover:opacity-90 transition-opacity" onclick="openModalWithGallery('${item.src}', '${item.alt || ''}', ${JSON.stringify(items).replace(/"/g, '&quot;')})"><video class="w-full h-full object-cover rounded" muted preload="metadata" playsinline>
              <source src="${item.src}" type="${item.src.endsWith('.MOV') || item.src.endsWith('.mov') ? 'video/quicktime' : 'video/mp4'}" />
            </video>
            <div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-30 opacity-0 hover:opacity-100 transition-opacity">
              <span class="text-4xl text-white drop-shadow-lg">▶</span>
            </div>
          </div>
        `;
      }
      contentHTML += '</div>';
    }
    
    contentHTML += '</div>';
    content.innerHTML = contentHTML;
    modal.appendChild(content);
    
    document.body.appendChild(modal);
    
    // Load video metadata for thumbnails in modal
    setTimeout(() => {
      const videos = modal.querySelectorAll('video[preload="metadata"]');
      videos.forEach(video => {
        video.addEventListener('loadedmetadata', function() {
          this.currentTime = 0.5;
        });
        video.load();
      });
    }, 100);
  }
  
  // Modal functionality with gallery navigation
  function openModalWithGallery(src, alt, items) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50';
    
    // Get current index
    let currentIndex = items.findIndex(item => item.src === src);
    if (currentIndex === -1) currentIndex = 0;
    
    // Create content container
    const contentContainer = document.createElement('div');
    contentContainer.className = 'relative max-w-[90%] max-h-[90vh]';
    
    // Update content based on current index
    function updateContent() {
      contentContainer.innerHTML = '';
      const currentItem = items[currentIndex];
      
      if (currentItem.type === 'video') {
        const video = document.createElement('video');
        video.src = currentItem.src;
        video.className = 'max-w-[90%] max-h-[90vh] object-contain';
        video.controls = true;
        video.autoplay = true;
        contentContainer.appendChild(video);
      } else {
        const image = document.createElement('img');
        image.src = currentItem.src;
        image.alt = currentItem.alt || '';
        image.className = 'max-w-[90%] max-h-[90vh] object-contain';
        contentContainer.appendChild(image);
      }
    }
    
    // Create navigation buttons
    const prevButton = document.createElement('button');
    prevButton.className = 'absolute left-4 top-1/2 -translate-y-1/2 bg-black bg-opacity-50 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-opacity-70 transition-colors';
    prevButton.innerHTML = '←';
    prevButton.onclick = function(e) {
      e.stopPropagation();
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      updateContent();
    };
    
    const nextButton = document.createElement('button');
    nextButton.className = 'absolute right-4 top-1/2 -translate-y-1/2 bg-black bg-opacity-50 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-opacity-70 transition-colors';
    nextButton.innerHTML = '→';
    nextButton.onclick = function(e) {
      e.stopPropagation();
      currentIndex = (currentIndex + 1) % items.length;
      updateContent();
    };
    
    // Create close button
    const closeButton = document.createElement('button');
    closeButton.className = 'absolute top-4 right-4 text-white text-2xl';
    closeButton.innerHTML = '&times;';
    closeButton.onclick = function() {
      modal.remove();
    };
    
    // Add keyboard navigation
    function handleKeyDown(e) {
      if (e.key === 'ArrowLeft') {
        currentIndex = (currentIndex - 1 + items.length) % items.length;
        updateContent();
      } else if (e.key === 'ArrowRight') {
        currentIndex = (currentIndex + 1) % items.length;
        updateContent();
      } else if (e.key === 'Escape') {
        modal.remove();
      }
    }
    
    modal.addEventListener('keydown', handleKeyDown);
    modal.tabIndex = 0;
    modal.focus();
    
    // Close modal when clicking outside
    modal.onclick = function(e) {
      if (e.target === modal) {
        modal.remove();
      }
    };
    
    // Initial content
    updateContent();
    
    // Add elements to modal
    contentContainer.appendChild(prevButton);
    contentContainer.appendChild(nextButton);
    contentContainer.appendChild(closeButton);
    modal.appendChild(contentContainer);
    document.body.appendChild(modal);
  }
  
  // Load video metadata to show first frame as thumbnail
  document.addEventListener('DOMContentLoaded', function() {
    const videos = document.querySelectorAll('video[preload="metadata"]');
    videos.forEach(video => {
      video.addEventListener('loadedmetadata', function() {
        this.currentTime = 0.5;
        this.pause();
      });
      // Force metadata loading
      video.load();
    });
  });
</script>
