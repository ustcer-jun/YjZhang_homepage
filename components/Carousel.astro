---
interface Props {
  items: {
    type: 'image' | 'video';
    src: string;
    alt?: string;
  }[];
  title: string;
}

const { items, title } = Astro.props;
---

<div class="mb-8">
  <h4 class="text-md font-medium mb-3 text-neutral-700 dark:text-neutral-300">{title}</h4>
  
  <!-- Carousel Container -->
  <div class="relative">
    <!-- Carousel Slides -->
    <div class="overflow-hidden">
      <div id="{title.replace(/\s+/g, '-').toLowerCase()}-carousel" class="flex transition-transform duration-300 ease-in-out">
        {items.map((item, index) => (
          <div key={index} class="flex-shrink-0 w-full sm:w-1/2 lg:w-1/3 px-2">
            <div class="p-2 border border-neutral-200 dark:border-neutral-800 rounded-lg">
              {item.type === 'image' ? (
                <img 
                  src={item.src} 
                  alt={item.alt || ''} 
                  class="w-full h-48 object-cover rounded cursor-pointer hover:opacity-90 transition-opacity"
                  onclick={`openModal('${item.src}', '${item.alt || ''}')`}
                />
              ) : (
                <div class="relative w-full h-48 bg-neutral-100 dark:bg-neutral-800 rounded cursor-pointer hover:opacity-90 transition-opacity"
                     onclick={`window.open('${item.src}', '_blank')`}>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-4xl">▶</span>
                  </div>
                  <span class="absolute bottom-2 right-2 bg-black bg-opacity-50 text-white text-xs px-2 py-1 rounded">
                    Video
                  </span>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Navigation Buttons -->
    {items.length > 3 && (
      <>
        <button 
          class="absolute left-0 top-1/2 -translate-y-1/2 bg-white dark:bg-neutral-800 rounded-full w-8 h-8 flex items-center justify-center shadow-md hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors z-10"
          onclick={`scrollCarousel('${title.replace(/\s+/g, '-').toLowerCase()}-carousel', -1)`}
        >
          ←
        </button>
        <button 
          class="absolute right-0 top-1/2 -translate-y-1/2 bg-white dark:bg-neutral-800 rounded-full w-8 h-8 flex items-center justify-center shadow-md hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors z-10"
          onclick={`scrollCarousel('${title.replace(/\s+/g, '-').toLowerCase()}-carousel', 1)`}
        >
          →
        </button>
      </>
    )}
  </div>
</div>

<script>
  // Modal functionality
  function openModal(src, alt) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50';
    modal.onclick = function(e) {
      if (e.target === modal) {
        modal.remove();
      }
    };
    
    const image = document.createElement('img');
    image.src = src;
    image.alt = alt;
    image.className = 'max-w-[90%] max-h-[90vh] object-contain';
    
    const closeButton = document.createElement('button');
    closeButton.className = 'absolute top-4 right-4 text-white text-2xl';
    closeButton.innerHTML = '&times;';
    closeButton.onclick = function() {
      modal.remove();
    };
    
    modal.appendChild(image);
    modal.appendChild(closeButton);
    document.body.appendChild(modal);
  }
  
  // Carousel scroll functionality
  function scrollCarousel(carouselId, direction) {
    const carousel = document.getElementById(carouselId);
    if (!carousel) return;
    const slide = carousel.querySelector('div');
    if (!slide) return;
    const slideWidth = slide.offsetWidth;
    const scrollAmount = slideWidth * direction;
    carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  }
</script>
