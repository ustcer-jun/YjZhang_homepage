---
import { t } from '../../i18n/helper';
import MainLayout from '../../layouts/MainLayout.astro';
import GalleryCarousel from '../../components/GalleryCarousel.astro';
import educationData from '../../data/education.json';
import publicationsData from '../../data/publications.json';
import blogsData from '../../data/blogs.json';
import sharesData from '../../data/shares.json';

const locale = 'zh';
---

<MainLayout title={t('hero.name', locale)} locale={locale}>
  <!-- Main Content -->
  <main class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-8">
      <!-- Left Sidebar -->
      <aside class="md:w-1/4 lg:w-1/5">
        <div class="sticky top-24 space-y-6">
          <!-- Profile Section -->
          <div class="text-center">
            <div class="w-32 h-32 mx-auto mb-4 rounded-full overflow-hidden border-2 border-primary dark:border-accent">
              <img 
                src="/profile.png" 
                alt="Profile" 
                class="w-full h-full object-cover"
              />
            </div>
            <h1 class="text-2xl font-bold mb-1 text-primary dark:text-white">{t('hero.name', locale)}</h1>
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">{locale === 'en' ? 'Master in Geophysics' : '地球物理学硕士'}</p>
            <p class="text-neutral-500 dark:text-neutral-500 text-sm mb-4">
              {locale === 'en' ? 'University of Science and Technology of China' : '中国科学技术大学'}
            </p>
            <p class="text-neutral-600 dark:text-neutral-400 text-sm">
              {locale === 'en' ? 'Hi~ this is my academic homepage.' : 'Hi~ 这是我的学术主页。'}
            </p>
          </div>
          
          <!-- Contact Info -->
          <div class="space-y-3">
            <a href="mailto:ustcer-jun@mail.ustc.edu.cn" class="flex items-center space-x-2 text-neutral-600 dark:text-neutral-400 hover:text-primary dark:hover:text-accent">
              <span>✉️</span>
              <span class="text-sm">{locale === 'en' ? 'Email' : '邮箱'}: ustcer-jun@mail.ustc.edu.cn</span>
            </a>
            <a href="#" class="flex items-center space-x-2 text-neutral-600 dark:text-neutral-400 hover:text-primary dark:hover:text-accent">
              <img src="/weixin.png" alt="WeChat" class="w-4 h-4 object-contain" />
              <span class="text-sm">{locale === 'en' ? 'WeChat/Phone' : '微信/电话'}: 18870037255</span>
            </a>
            <div class="flex items-center space-x-2 text-neutral-600 dark:text-neutral-400">
              <img src="/qq.png" alt="QQ" class="w-4 h-4 object-contain" />
              <span class="text-sm">{locale === 'en' ? 'QQ: 1597053457' : 'QQ: 1597053457'}</span>
            </div>
            <a href="#" class="flex items-center space-x-2 text-neutral-600 dark:text-neutral-400 hover:text-primary dark:hover:text-accent">
              <span>📍</span>
              <span class="text-sm">{locale === 'en' ? 'Hefei, China' : '中国合肥'}</span>
            </a>
          </div>
        </div>
      </aside>
      
      <!-- Right Main Content -->
      <div class="md:w-3/4 lg:w-4/5">
        <!-- Introduction Section -->
        <section id="introduction" class="mb-12">
          <h2 class="text-xl font-bold mb-4 text-primary dark:text-white">{locale === 'en' ? 'Introduction' : '个人简介'}</h2>
          <div class="prose dark:prose-invert max-w-none">
            <p class="mb-4">
              {locale === 'en' ? 'I graduated from East China University of Technology with a bachelor\'s degree in Exploration Technology and Engineering. I am currently a combined masters and doctoral student in Geophysics at the University of Science and Technology of China.' : '本科毕业于东华理工大学勘查技术与工程专业，现于中国科学技术大学地球物理学专业硕博连读。'}
            </p>
            <p class="mb-6">
              {locale === 'en' ? 'My main research direction is crustal deformation monitoring using the open-source satellite SAR data processing software GMTSA, combined with seismic and geological activity characteristics, to quantitatively invert fault physical properties and tectonic dynamic processes.' : '主要研究方向为利用开源卫星SAR数据处理软件GMTSA进行地壳形变监测，结合地震地质活动特征，定量反演断层物理性质与构造动力学过程。'}
            </p>
            
            <h3 class="text-lg font-semibold mb-3 text-primary dark:text-accent">{locale === 'en' ? 'Research Interests' : '研究兴趣'}</h3>
            <ul class="list-disc pl-5 mb-6 space-y-1">
              <li>{locale === 'en' ? 'Earthquake Geodesy' : '地震大地测量学'}</li>
              <li>{locale === 'en' ? 'Satellite Geodesy' : '卫星大地测量学'}</li>
              <li>{locale === 'en' ? 'Geophysical Inversion' : '地球物理反演'}</li>
            </ul>
            
            <h3 class="text-lg font-semibold mb-3 text-primary dark:text-accent">{locale === 'en' ? 'Fun Facts' : '兴趣爱好'}</h3>
            <div class="grid grid-cols-3 gap-4">
              <div class="p-3 border border-neutral-200 dark:border-neutral-800 rounded-lg text-center">
                <span>{locale === 'en' ? 'Vibe coding' : '编程'}</span>
              </div>
              <div class="p-3 border border-neutral-200 dark:border-neutral-800 rounded-lg text-center">
                <span>{locale === 'en' ? 'Sports' : '运动'}</span>
              </div>
              <div class="p-3 border border-neutral-200 dark:border-neutral-800 rounded-lg text-center">
                <span>{locale === 'en' ? 'Traveling' : '旅行'}</span>
              </div>
            </div>
          </div>
        </section>
        
        <!-- Education Section -->
        <section id="education" class="mb-12">
          <h2 class="text-xl font-bold mb-4 text-primary dark:text-white">{locale === 'en' ? 'Education' : '教育背景'}</h2>
          <div class="space-y-4">
            {educationData.filter(item => item.id !== 1).map((item, index) => (
              <div key={item.id} class="p-4 border border-neutral-200 dark:border-neutral-800 rounded-lg">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
                  <div class="flex items-center space-x-3 mb-1 md:mb-0">
                    {item.institution.includes('东华理工大学') && (
                      <img src="/ECUT.png" alt="ECUT" class="w-8 h-8 object-contain" />
                    )}
                    {item.institution.includes('中国科学技术大学') && (
                      <img src="/ustcblue.jpg" alt="USTC" class="w-8 h-8 object-contain" />
                    )}
                    <div class="font-semibold text-primary dark:text-accent">
                      {locale === 'en' ? 
                        (item.institution === '东华理工大学' ? 'East China University of Technology' : 
                         item.institution === '中国科学技术大学' ? 'University of Science and Technology of China' : 
                         item.institution)
                        : item.institution
                      }
                    </div>
                  </div>
                  <div class="text-neutral-500 dark:text-neutral-500 text-sm">
                    {locale === 'en' ? 
                      (item.period === '2019.9 - 2023.7' ? '2019.9 - 2023.7' : 
                       item.period === '2023.9 - 至今' ? '2023.9 - Present' : 
                       item.period === '至今 - 未来' ? 'Present - Future' : 
                       item.period)
                      : item.period
                    }
                  </div>
                </div>
                <div class="text-neutral-600 dark:text-neutral-400">
                  {locale === 'en' ? 
                    (item.degree === '本科 - 勘查技术与工程' ? 'Bachelor - Exploration Technology and Engineering' : 
                     item.degree === '硕士 - 固体地球物理学' ? 'Master - Solid Earth Geophysics' : 
                     item.degree === '博士 - 固体地球物理学' ? 'Ph.D - Solid Earth Geophysics' : 
                     item.degree)
                    : item.degree
                  }
                </div>
              </div>
            ))}
          </div>
        </section>
        
        <!-- Publications Section -->
        <section id="publications" class="mb-12">
          <h2 class="text-xl font-bold mb-4 text-primary dark:text-white">{locale === 'en' ? 'Publications' : '发表论文'}</h2>
          <div class="space-y-4">
            {publicationsData.map((pub, index) => (
              <div key={pub.id} class="p-4 border border-neutral-200 dark:border-neutral-800 rounded-lg">
                <h3 class="font-semibold text-primary dark:text-white mb-2">{pub.title}</h3>
                <p class="text-neutral-600 dark:text-neutral-400 mb-2">
                  {pub.authors.map((author, authorIndex) => (
                    <span key={authorIndex} class={author === 'Your Name' ? 'font-bold' : ''}>
                      {author}{authorIndex < pub.authors.length - 1 ? ', ' : ''}
                    </span>
                  ))}
                </p>
                <p class="text-neutral-600 dark:text-neutral-400 mb-2">
                  {pub.journal}, Volume {pub.volume}, Issue {pub.issue}, {pub.year}
                </p>
                <p class="text-neutral-600 dark:text-neutral-400 mb-3">
                  DOI: <a href={pub.doi} target="_blank" rel="noopener noreferrer" class="text-primary dark:text-accent hover:underline">{pub.doi.split('/').pop()}</a>
                </p>
                <div class="flex space-x-4">
                  <a href={pub.doi} target="_blank" rel="noopener noreferrer" class="text-sm text-primary dark:text-accent hover:underline">
                    DOI
                  </a>
                  <a href={pub.pdf} target="_blank" rel="noopener noreferrer" class="text-sm text-primary dark:text-accent hover:underline">
                    PDF
                  </a>
                </div>
              </div>
            ))}
          </div>
        </section>
        
        <!-- Links Section -->
        <section id="links" class="mb-12">
          <h2 class="text-xl font-bold mb-4 text-primary dark:text-white">{t('blog.title', locale)}</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {blogsData.map((blog, index) => (
              <a 
                key={blog.id} 
                href={blog.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-center space-x-2 p-3 border border-neutral-200 dark:border-neutral-800 rounded-lg hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors"
              >
                <div class="w-6 h-6 flex items-center justify-center">
                  {blog.icon === 'github' && (
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  )}
                  {blog.icon === 'csdn' && (
                    <img src="/csdn.png" alt="CSDN" class="w-5 h-5 object-contain" />
                  )}
                  {blog.icon === 'bilibili' && (
                    <img src="/b_zhan.png" alt="Bilibili" class="w-5 h-5 object-contain" />
                  )}
                  {blog.icon === 'netease' && (
                    <img src="/wangyiyun.png" alt="NetEase" class="w-5 h-5 object-contain" />
                  )}
                </div>
                <span class="text-sm font-medium text-neutral-700 dark:text-neutral-300">
                  {locale === 'zh' ? blog.name : blog.name_en || blog.name}
                </span>
              </a>
            ))}
          </div>
        </section>
        
        <!-- Personal Share Section -->
        <section id="personal-share" class="mb-12">
          <h2 class="text-xl font-bold mb-4 text-primary dark:text-white">{t('shares.title', locale)}</h2>
          <div class="space-y-8">
            <!-- Travel Footprints -->
            <GalleryCarousel 
              title={t('shares.travel', locale)}
              galleries={sharesData.travel.galleries}
              locale={locale}
            />
            
            <!-- Daily Life -->
            <GalleryCarousel 
              title={t('shares.daily', locale)}
              galleries={sharesData.daily.galleries}
              locale={locale}
            />
            
            <!-- Conferences & Research -->
            <GalleryCarousel 
              title={t('shares.conferences', locale)}
              galleries={sharesData.conferences.galleries}
              locale={locale}
            />
          </div>
        </section>
      </div>
    </div>
  </main>
</MainLayout>
